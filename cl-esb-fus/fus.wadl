
<application xmlns="http://wadl.dev.java.net/2009/02" xmlns:xs="http://www.w3.org/2001/XMLSchema"><grammars><xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:tns="http://www.optaintel.ca/ws/OptaSingleService/1.0" attributeFormDefault="unqualified" elementFormDefault="qualified" targetNamespace="http://www.optaintel.ca/ws/OptaSingleService/1.0">
<xs:element name="OSSRequest" type="tns:OSSRequestType"/>
<xs:element name="OSSResponse" type="tns:OSSResponseType"/>
<xs:complexType name="ResultType">
<xs:sequence>
<xs:element name="ActivityID" type="xs:string"/>
<xs:element name="Address" type="tns:ResponseAddressType"/>
<xs:element name="ProductResults" type="tns:ProductResultsType"/>
<xs:element maxOccurs="unbounded" minOccurs="0" name="Message" type="xs:string"/>
</xs:sequence>
</xs:complexType>
<xs:complexType name="ResponseAddressType">
<xs:sequence>
<xs:element minOccurs="0" name="AddressID" type="xs:string"/>
<xs:element minOccurs="0" name="OptaAddressKey" type="xs:string"/>
<xs:element name="StreetNumber" type="xs:string"/>
<xs:element name="StreetName" type="xs:string"/>
<xs:element minOccurs="0" name="StreetType" type="xs:string"/>
<xs:element minOccurs="0" name="StreetDirection" type="xs:string"/>
<xs:element minOccurs="0" name="UnitNumber" type="xs:string"/>
<xs:element name="Municipality" type="xs:string"/>
<xs:element name="Province" type="tns:ProvinceType"/>
<xs:element minOccurs="0" name="PostalCode" type="xs:string"/>
</xs:sequence>
</xs:complexType>
<xs:complexType name="ProductResultsType">
<xs:sequence>
<xs:choice maxOccurs="unbounded" minOccurs="0">
<xs:element name="PerilScoreProduct" type="tns:PerilScoreProductType"/>
<xs:element name="InspectionScoreProduct" type="tns:InspectionScoreProductType"/>
<xs:element name="iClarifyCondoTenantProduct" type="tns:iClarifyCondoTenantProductType"/>
<xs:element name="CommercialPerilScoreProduct" type="tns:CommercialPerilScoreProductType"/>
<xs:element name="FloodScoreProduct" type="tns:FloodScoreProductType"/>
<xs:element name="iClarifyResidentialProduct" type="tns:iClarifyResidentialProductType"/>
<xs:element name="FUSProduct" type="tns:FUSProductType"/>
<xs:element name="iClarifyCommercialOccupancyProduct" type="tns:iClarifyCommercialOccupancyProductType"/>
<xs:element name="InspectionAttributesProduct" type="tns:InspectionAttributesProductType"/>
</xs:choice>
</xs:sequence>
</xs:complexType>
